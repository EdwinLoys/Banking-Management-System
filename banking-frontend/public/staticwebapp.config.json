{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [ "/static/*", "/*.{png,jpg,gif,ico,css,js}" ]
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [ "anonymous" ]
        },
        {
            "route": "/*",
            "serve": "/index.html",
            "statusCode": 200
        }
    ]
}